# Supabase (public — safe in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Public app URL (used for absolute URLs in OG tags, emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL of the @crm/api service. In Railway: http://api.railway.internal:8080
API_URL=http://localhost:8080

# --- Server-only ---
# These are needed by Server Actions and API routes that still live in apps/web
# during Phase 1. They move out to apps/api in Phase 2 and can be removed here then.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
SUPABASE_DB_POOLER_URL=postgresql://...
OPENAI_API_KEY=sk-proj-...
OPENAI_EXPENSE_MODEL=gpt-4o
